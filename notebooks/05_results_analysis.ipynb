import sys
sys.path.insert(0, "..")

import json
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path

plt.rcParams["figure.dpi"] = 120
sns.set_style("whitegrid")

RESULTS_DIR = Path("../results")
print("Results directory:", RESULTS_DIR)

result_files = sorted(RESULTS_DIR.glob("*.json"))
print("Found result files:")
for f in result_files:
    print(f"  {f.name}")

all_results = {}
for f in result_files:
    with open(f, encoding="utf-8") as fh:
        all_results[f.stem] = json.load(fh)

print(f"\nLoaded {len(all_results)} result files.")

# === Final Model Comparison Table ===
comparison_metrics = ["auroc", "f1_macro", "sensitivity", "specificity", 
                     "precision", "npv", "accuracy"]

model_names = [
    "Logistic Regression",
    "Shallow CNN",
    "ResNet-18 Fine-tune",
    "DenseNet-Attention"
]

# Extract results
baseline = all_results.get("baseline_results", {})
models = all_results.get("model_results", {})

results_map = {
    "Logistic Regression": baseline.get("logistic_regression", {}),
    "Shallow CNN": baseline.get("shallow_cnn", {}),
    "ResNet-18 Fine-tune": models.get("resnet18", {}),
    "DenseNet-Attention": models.get("densenet_attention", {}),
}

rows = []
for name in model_names:
    m = results_map.get(name, {})
    row = {"Model": name}
    for metric in comparison_metrics:
        value = m.get(metric, 0)
        row[metric.upper()] = f"{value:.4f}"
    rows.append(row)

df_comparison = pd.DataFrame(rows)
print("=== FINAL MODEL COMPARISON ===")
print(df_comparison.to_string(index=False))

print("\n" + "="*60)
print("KEY TAKEAWAYS")
print("="*60)

print("• DenseNet-Attention achieves the best overall balance")
print("• Both deep models vastly outperform baselines thanks to transfer learning")
print(f"• Specificity remains the weakest point: {df_comparison.iloc[3]['SPECIFICITY']}")
print("• High sensitivity (>99%) makes the model excellent for ruling out pneumonia")

# Load test predictions if available from error analysis
try:
    # Assuming you saved test predictions in results
    with open(RESULTS_DIR / "test_predictions.json", encoding="utf-8") as f:
        test_data = json.load(f)
    probs = np.array(test_data["probs"])
    labels = np.array(test_data["labels"])
    
    # Confidence bins
    bins = [0.0, 0.6, 0.8, 0.9, 0.95, 0.99, 1.0]
    bin_labels = pd.cut(probs, bins=bins, labels=[f"{bins[i]:.2f}-{bins[i+1]:.2f}" for i in range(len(bins)-1)])
    
    error_rate = []
    for b in bin_labels.categories:
        mask = bin_labels == b
        if mask.sum() > 0:
            err = (labels[mask] != (probs[mask] >= 0.5).astype(int)).mean()
            error_rate.append(err)
        else:
            error_rate.append(np.nan)
    
    print("Error Rate by Confidence Level:")
    for b, rate in zip(bin_labels.categories, error_rate):
        print(f"  Confidence {b}: Error rate = {rate:.1%}" if not np.isnan(rate) else "")
        
except:
    print("Test predictions not found. Run notebook 06 first.")

