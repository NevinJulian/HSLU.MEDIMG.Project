import sys
sys.path.insert(0, "..")

import numpy as np
import torch
import matplotlib.pyplot as plt
import seaborn as sns
import pandas as pd
from pathlib import Path

from src.data import get_dataloaders
from src.models import get_model
from src.evaluate import evaluate_model, generate_gradcam, plot_gradcam_grid, plot_confusion_matrix

plt.rcParams["figure.dpi"] = 120
sns.set_style("whitegrid")

config = load_config("../configs/default.yaml")
device = get_device()
DATA_ROOT = "../data/chest_xray"
SEED = config["reproducibility"]["seed"]

print(f"Device: {device}")

set_seed(SEED)

dataloaders = get_dataloaders(
    DATA_ROOT,
    augmentation="standard",
    image_size=config["data"]["image_size"],
    batch_size=32,
    num_workers=0,
    seed=SEED
)

# Load best model
model = get_model("densenet_attention", pretrained=True, use_attention=True)
checkpoint_path = "../results/checkpoints/densenet_attention_best.pt"

model.load_state_dict(torch.load(checkpoint_path, map_location=device, weights_only=True))
model = model.to(device)
model.eval()

print("Model loaded successfully from checkpoint")

all_images, all_labels, all_probs = [], [], []

with torch.no_grad():
    for images, labels in dataloaders["test"]:
        outputs = model(images.to(device)).squeeze()
        probs = torch.sigmoid(outputs).cpu().numpy()
        all_images.append(images)
        all_labels.append(labels)
        all_probs.extend(probs)

all_images = torch.cat(all_images)
all_labels = torch.cat(all_labels).numpy()
all_probs = np.array(all_probs)
all_preds = (all_probs >= 0.5).astype(int)

print(f"Test set: {len(all_labels)} images")
print(f"Normal: {np.sum(all_labels == 0)} | Pneumonia: {np.sum(all_labels == 1)}")

# Confidence bins
bins = [0.0, 0.5, 0.7, 0.85, 0.95, 0.99, 1.0]
bin_labels = pd.cut(all_probs, bins=bins, labels=[f"{bins[i]:.2f}-{bins[i+1]:.2f}" for i in range(len(bins)-1)])

correct = all_labels == all_preds
error_rate_per_bin = []

print("=== ERROR RATE BY CONFIDENCE LEVEL ===\n")
for b in bin_labels.categories:
    mask = bin_labels == b
    if mask.sum() > 0:
        error_rate = (~correct[mask]).mean()
        count = mask.sum()
        print(f"Confidence {b:>12s}: {count:3d} samples | Error rate = {error_rate:.1%}")

fp_idx = np.where((all_preds == 1) & (all_labels == 0))[0]   # False Positives
fn_idx = np.where((all_preds == 0) & (all_labels == 1))[0]   # False Negatives

print(f"False Positives : {len(fp_idx)} ({len(fp_idx)/len(all_labels)*100:.1f}%)")
print(f"False Negatives: {len(fn_idx)} ({len(fn_idx)/len(all_labels)*100:.1f}%)")

# High-confidence mistakes
high_conf_fp = fp_idx[np.argsort(all_probs[fp_idx])[-8:]]   # Top 8 confident FPs
high_conf_fn = fn_idx[np.argsort(all_probs[fn_idx])[:8]]    # Most uncertain FNs

# High-confidence False Positives
print("Generating Grad-CAM for high-confidence False Positives...")
heatmaps_fp = generate_gradcam(model, all_images[high_conf_fp], 
                               target_layer=model.features.denseblock4.denselayer16.conv2, device=device)

fig_fp = plot_gradcam_grid(all_images[high_conf_fp], heatmaps_fp, 
                           all_labels[high_conf_fp], all_probs[high_conf_fp], 
                           n_samples=8, title="High-Confidence False Positives")
plt.show()

# High-confidence False Negatives
print("Generating Grad-CAM for False Negatives...")
heatmaps_fn = generate_gradcam(model, all_images[high_conf_fn], 
                               target_layer=model.features.denseblock4.denselayer16.conv2, device=device)

fig_fn = plot_gradcam_grid(all_images[high_conf_fn], heatmaps_fn, 
                           all_labels[high_conf_fn], all_probs[high_conf_fn], 
                           n_samples=8, title="False Negatives")
plt.show()

thresholds = [0.3, 0.5, 0.7, 0.85, 0.95]
print("=== CLINICAL THRESHOLD ANALYSIS ===\n")

for t in thresholds:
    metrics = compute_metrics(all_labels, all_probs, threshold=t)
    print(f"Threshold {t:.2f}: "
          f"Sens={metrics['sensitivity']:.3f} | "
          f"Spec={metrics['specificity']:.3f} | "
          f"F1={metrics['f1_macro']:.3f} | "
          f"NPV={metrics['npv']:.3f}")
##Key Insights from Error Analysis

- The model is very confident when correct, but also sometimes overconfident on errors.
- False Positives often occur on images with artifacts or overlapping structures.
- False Negatives tend to be subtle or early-stage pneumonia cases.
- High sensitivity at low thresholds makes it suitable for **screening**.
- Better specificity at higher thresholds makes it suitable for **second reader**.
